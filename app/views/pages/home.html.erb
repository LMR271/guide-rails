<% random_avatar = "avatars/avatar#{rand(1..6)}.png" %>
<% if user_signed_in? %>
  <%# ============ DASHBOARD (logged in) ============ %>
  <div class="container-fluid" style="max-width: 1200px;">
    <div class="banner p-5">
      <div class="row align-items-start">
        <div class="col text-start">
          <br>
          <h1 class="geist-pixel-brand">Welcome back, <strong><%= current_user.nickname.presence || current_user.first_name || "there" %>!</strong></h1>
          <p>Are you ready to learn more about Ruby on Rails with our interactive documentation?</p>
          <p>You can decide whether you:</p>
          <ul>
            <li>Would you like to <strong>continue learning</strong> about a specific concept that you have already investigated? Then just look at your <strong><%= link_to "past chats", chats_path, style: "color: inherit; text-decoration: none;" %></strong>.</li>
            <br>
            <li>Start a <strong>new GuideRails Chat</strong> to help you understand new concepts? Click on the <strong><%= link_to "start a chat", new_chat_path, style: "color: inherit; text-decoration: none;" %></strong> to begin with a new topic!</li>
          </ul>

          <div class="card mt-4">
            <div class="card-header d-flex justify-content-between align-items-center">
              <span><strong></strong>Past chats</strong></span>
              <% if @total_chats > 5 %>
                <%= link_to "View all →", chats_path, class: "btn btn-sm btn-outline-secondary" %>
              <% end %>
            </div>

            <% if @chats.any? %>
              <ul class="list-group list-group-flush">
                <% @chats.each do |chat| %>
                  <li class="list-group-item d-flex justify-content-between align-items-center">
                    <%= link_to chat.topic, chat_path(chat) %>
                    <%= button_to "🗑️", chat_path(chat), method: :delete,
                          class: "btn btn-sm btn-outline-danger",
                          data: { turbo_confirm: "Delete this chat?" } %>
                  </li>
                <% end %>
              </ul>
            <% else %>
              <div class="card-body text-center text-muted">
                <p class="mb-0">You haven't started any chats yet.</p>
              </div>
            <% end %>
          </div>

          <br>
          <%= link_to "Start a chat!", new_chat_path, class: "btn btn-danger" %>
        </div>

        <div class="col">
          <%= image_tag "avatars/avatar#{rand(1..6)}.png",
              id: "image",
              class: "img-fluid",
              alt: "GuideRails avatar" %>
        </div>
      </div>
    </div>
  </div>


<% else %>
  <%# ============ LANDING (logged out) ============ %>
  <div class="container-fluid" style="max-width: 1200px;">
    <div class="banner p-5">
      <div class="row align-items-start">
        <div class="col text-start">
          <br>
          <h1>Welcome to <strong>GuideRails!</strong></h1>
          <p>Your <strong>interactive Ruby on Rails documentation assistant</strong></p><br>
          <p>Stop digging through scattered docs, Stack Overflow threads, and outdated tutorials. GuideRails lets you ask a direct question and get a clear, focused answer — grounded in Ruby on Rails concepts.</p>
          <p><strong>What you can do with GuideRails:</strong></p>
          <ul id="advantage-list">
            <li>💬 Ask any question about Ruby on Rails and get an instant, relevant answer</li>
            <li>📚 Get explanations tied directly to official Rails documentation and conventions</li>
            <li>🕘 Revisit your past chats anytime — nothing gets lost</li>
            <li>🚀 Start a new chat in one click whenever a new question comes up</li>
            <li>🔒 Your own account, your own chat history — sign up in seconds</li>
          </ul><br>
          <%= link_to "Sign Up", new_user_registration_path, class: "btn btn-outline-secondary" %>
        </div>
        <div class="col">
          <%= image_tag "avatars/avatar#{rand(1..6)}.png",
              id: "image",
              class: "img-fluid",
              alt: "GuideRails avatar" %>
        </div>
      </div>
    </div>
  </div>
<% end %>
