<%= link_to "← Back", chats_path, class: "btn btn-sm btn-outline-secondary mb-3" %>

<h2 class="mb-4"><%= @chat.topic %></h2>

<div class="border rounded p-4 mb-3" style="min-height: 300px;">
  <p class="text-muted mb-0">Conversation will appear here.</p>
</div>

<div class="input-group">
  <input type="text" class="form-control" placeholder="Ask a question…" disabled>
  <button class="btn btn-danger" disabled>Send</button>
</div>
