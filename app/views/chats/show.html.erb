<div class="container-fluid" style="max-width: 1200px;">
  <div class="banner p-5">

    <div class="d-grid align-items-center mb-4" style="grid-template-columns: 1fr auto 1fr;">
      <%= link_to "← Back", chats_path, class: "btn btn-sm btn-outline-secondary", style: "justify-self: start;" %>
      <h1 id="chat_title" class="text-center mb-0 geist-pixel-brand"><%= @chat.topic %></h1>
      <span></span>
    </div>


      <div class="card mb-3">
        <div id="messages" class="card-body">
          <% if @chat.messages.any? %>
            <%= render "messages/messages", messages: @chat.messages.order(:created_at) %>
          <% else %>
            <div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted">
              <i class="fa-solid fa-comments fa-2x mb-2"></i>
              <p class="mb-0">Conversation will appear here.</p>
            </div>
          <% end %>
        </div>
      </div>

      <div id="new_message_container">
        <%= render "messages/form", chat: @chat, message: @message %>
      </div>

    </div>
  </div>
