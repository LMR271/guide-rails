<div class="container-fluid" style="max-width: 1200px;">
  <div class="banner p-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1 id="chat_title" class="mb-0"><%= @chat.topic %></h1>
      <%= link_to "← Back", chats_path, class: "btn btn-sm btn-outline-secondary" %>
    </div>

      <div class="card mb-3">
        <div id="messages" class="card-body" style="min-height: 300px;">
          <% if @ai_answer.present? %>
            <p><strong>You:</strong> <%= @user_question %></p>
            <p><strong>AI:</strong> <%= @ai_answer %></p>
          <% else %>
            <p class="text-muted mb-0">Conversation will appear here.</p>
          <% end %>
        </div>
      </div>
  
      <%= form_with url: chat_messages_path(@chat), method: :post, data: { turbo: false } do |form| %>
        <div id="new_message_container" class="input-group">
          <%= form.text_field :content, class: "form-control", placeholder: "Ask a question…" %>
          <%= form.submit "Send", class: "btn btn-danger" %>
        </div>
      <% end %>

    </div>
  </div>

