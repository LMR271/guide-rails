<div class="container-fluid" style="max-width: 1200px;">
  <div class="banner p-5">

    <div class="d-grid align-items-center mb-4" style="grid-template-columns: 1fr auto 1fr;">
      <%= link_to "← Home", root_path, class: "btn btn-sm btn-outline-secondary", style: "justify-self: start;" %>
      <h1 class="text-center geist-pixel-brand mb-0">Past chats</h1>
      <span></span>
    </div>


    <div class="card">
      <% if @chats.any? %>
        <ul class="list-group list-group-flush">
          <% @chats.each do |chat| %>
            <li class="list-group-item d-flex justify-content-between align-items-center">
              <%= link_to chat.topic, chat_path(chat) %>
              <%= button_to chat_path(chat), method: :delete,
                    class: "btn btn-sm btn-outline-danger",
                    data: { turbo_confirm: "Delete this chat?" },
                    aria: { label: "Delete chat" } do %>
                <i class="fa-solid fa-trash-can"></i>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="card-body text-center text-muted">
          <p class="mb-3">You haven't started any chats yet.</p>
          <%= link_to "Start your first chat", new_chat_path, class: "btn btn-danger" %>
        </div>
      <% end %>
    </div>

  </div>
</div>
