<div class="container">
  <%= link_to "← Back", chats_path, class: "btn btn-sm btn-outline-secondary" %>

  <h1 class="mt-2">Start a new chat</h1>

  <%= form_with model: @chat do |f| %>
    <% if @chat.errors.any? %>
      <div class="alert alert-danger">
        <%= @chat.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div class="mb-3">
      <%= f.label :topic, "Chat topic" %>
      <%= f.text_field :topic, class: "form-control", placeholder: "e.g. Active Record Associations" %>
    </div>

    <%= f.submit "Create chat", class: "btn btn-danger" %>
  <% end %>
</div>
