<div class="container-fluid" style="max-width: 1200px;">
  <div class="banner p-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1 class="mb-0">Start a new chat</h1>
      <%= link_to "← Back", chats_path, class: "btn btn-sm btn-outline-secondary" %>
    </div>

    <div class="card">
      <div class="card-body">
        <%= form_with model: @chat do |f| %>
          <% if @chat.errors.any? %>
            <div class="alert alert-danger">
              <%= @chat.errors.full_messages.to_sentence %>
            </div>
          <% end %>

          <div class="mb-3">
            <%= f.label :topic, "Chat topic", class: "form-label" %>
            <%= f.text_field :topic, class: "form-control", placeholder: "e.g. Active Record Associations" %>
          </div>

          <%= f.submit "Create chat", class: "btn btn-danger" %>
        <% end %>
      </div>
    </div>

  </div>
</div>
