<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">

      <div class="card shadow p-4">

        <h2 class="text-center mb-4">Account Settings</h2>

        <%= simple_form_for @user, url: profile_path, method: :patch do |f| %>

          <div class="form-inputs">
            <%= f.input :nickname,
                        label: "Display Name",
                        placeholder: "Choose a display name" %>
          </div>

          <div class="form-actions mt-3">
            <%= f.button :submit,
                         "Save Changes",
                         class: "btn btn-dark w-100" %>
          </div>

        <% end %>

        <hr class="my-4">

        <div class="settings-section-title mb-2">
          Security
        </div>

        <%= link_to "Change Password",
            edit_user_registration_path,
            class: "btn btn-outline-secondary w-100" %>

        <div class="settings-section-title text-danger mt-4 mb-2">
          Danger Zone
        </div>

        <%= button_to "Delete Account",
            registration_path(current_user),
              method: :delete,
              data: {
                turbo_confirm: "Are you sure? This action cannot be undone."
              },
              class: "btn btn-outline-danger w-100" %>

      </div>

    </div>
  </div>
</div>
