<%= simple_form_for [chat, message] do |f| %>
  <% if message.errors.any? %>
    <div class="alert alert-danger">
      <%= message.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="input-group">
    <%= f.input_field :content, class: "form-control", placeholder: "Ask a question…", autocomplete: "off" %>
    <%= f.button :submit, "Send", class: "btn btn-danger" %>
  </div>
<% end %>
